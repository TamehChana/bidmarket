PORT=4000
FRONTEND_URL=http://localhost:3000

# Fapshi (Cameroon — MTN MoMo & Orange Money)
# 1. Create a service at https://fapshi.com
# 2. Copy apiuser + apikey (sandbox keys start with FAK_TEST_)
# 3. Leave FAPSHI_API_USER and FAPSHI_API_KEY empty for mock payment mode locally
FAPSHI_ENV=sandbox
FAPSHI_API_USER=
FAPSHI_API_KEY=
FAPSHI_WEBHOOK_SECRET=
# OpenAI — powers listing assistant, smart search, bid coach, admin moderation
OPENAI_API_KEY=

# Optional: password for seeded demo accounts (demo@, seller@, admin@bidmarket.com)
SEED_ACCOUNT_PASSWORD=
